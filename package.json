{
  "name": "@freelensapp/resource-map-extension",
  "version": "1.0.1",
  "description": "FreeLens extension to visualize Kubernetes resources and their relations",
  "homepage": "https://github.com/freelensapp/freelens-resource-map-extension",
  "license": "MIT",
  "author": "Yasmine Gharbi <gyasmine29@gmail.com>",
  "contributors": [
    {
      "name": "Omar Luqman",
      "url": "https://github.com/omarluq"
    },
    {
      "name": "Yasmine Gharbi",
      "url": "https://github.com/GHARBIyasmine"
    },
    {
      "name": "Lauri Nevala",
      "url": "https://github.com/nevalla"
    }
  ],
  "publisher": "freelens",
  "repository": {
    "type": "git",
    "url": "https://github.com/freelensapp/freelens-resource-map-extension.git"
  },
  "main": "out/main/index.js",
  "renderer": "out/renderer/index.js",
  "engines": {
    "node": ">=22.0.0",
    "freelens": "^1.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "lens",
    "extension",
    "k8slens",
    "kubernetes",
    "freelensapp",
    "extension",
    "lens",
    "openlens",
    "freelens",
    "resource",
    "map"
  ],
  "files": [
    "out/**/*"
  ],
  "updateSource": "github|npmjs",
  "scripts": {
    "biome": "corepack pnpm dlx @biomejs/biome@2.3.6",
    "biome:check": "corepack pnpm biome check",
    "biome:fix": "corepack pnpm biome check --fix",
    "biome:migrate": "corepack pnpm biome migrate --write",
    "prettier": "corepack pnpm dlx prettier@3.6.2",
    "prettier:check": "corepack pnpm prettier --check .",
    "prettier:fix": "corepack pnpm prettier --write .",
    "trunk": "corepack pnpm dlx @trunkio/launcher@1.3.4",
    "trunk:check": "corepack pnpm trunk check",
    "trunk:check:all": "corepack pnpm trunk check --all",
    "trunk:fix": "corepack pnpm trunk check --fix",
    "trunk:fix:all": "corepack pnpm trunk check --fix --all",
    "lint": "corepack pnpm lint:check",
    "lint:check": "corepack pnpm \"/^(biome|prettier):check\\$/\"",
    "lint:fix": "corepack pnpm \"/^(biome|prettier):fix\\$/\"",
    "knip": "corepack pnpm dlx knip@5.70.0 --dependencies --no-gitignore",
    "knip:check": "corepack pnpm \"/^knip:(development|production)\\$/\"",
    "knip:development": "corepack pnpm knip",
    "knip:production": "corepack pnpm knip --production --strict",
    "type:check": "tsc --noEmit -p tsconfig.json --composite false",
    "prebuild": "corepack pnpm type:check",
    "build": "electron-vite build",
    "build:production": "VITE_PRESERVE_MODULES=false electron-vite build",
    "build:force": "electron-vite build",
    "bump-version": "corepack pnpm version --no-commit-hooks --no-git-tag-version",
    "pack:dev": "corepack pnpm bump-version prerelease && corepack pnpm build:force && corepack pnpm build && corepack pnpm clean:tgz && corepack pnpm pack && corepack pnpm dlx shx@0.4.0 ls \"$PWD/*.tgz\"",
    "clean": "corepack pnpm clean:out",
    "clean:dts": "corepack pnpm dlx shx@0.4.0 rm -f \"src/**/*.scss.d.ts\"",
    "clean:node_modules": "corepack pnpm dlx shx@0.4.0 rm -rf node_modules",
    "clean:out": "corepack pnpm dlx shx@0.4.0 rm -rf out",
    "clean:tgz": "corepack pnpm dlx shx@0.4.0 rm -f \"*.tgz\"",
    "clean:all": "corepack pnpm \"/^clean:(dts|node_modules|out|tgz)\\$/\"",
    "postupdate": "corepack pnpm biome:migrate"
  },
  "contributes": {
    "crds": [],
    "cloudProviders": [],
    "kubernetesDistros": []
  },
  "overrides": {
    "react": "^17.0.2",
    "@types/react": "^17.0.85"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron-vite": "^4.0.1",
    "vite": "^7.3.2",
    "vite-plugin-external": "^6.2.2",
    "vite-plugin-sass-dts": "^1.3.35",
    "@freelensapp/extensions": "^1.6.0",
    "@freelensapp/utilities": "^1.6.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^17.0.85",
    "@types/react-dom": "^17.0.26",
    "d3-force": "^3.0.0",
    "mobx": "^6.10.2",
    "mobx-react": "^7.6.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-force-graph-2d": "^1.27.1",
    "sass": "^1.97.3",
    "type-fest": "^2.19.0",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
